# --- Dagobservatie ---

ex:obs-FMN-021-20260428-dag a sosa:Observation ;
    rdfs:label "Dagsom FMN-021 op 28 april 2026"@nl ;
    sosa:relatedObservation ex:collectie-FMN-021-20260428 ;
    sosa:hasInputValue ex:collectie-FMN-021-20260428 ;
    sosa:madeBySensor ex:teller-FMN-021 ;
    sosa:usedProcedure ex:procedure-automatisch-tellen ;
    sosa:hasFeatureOfInterest ex:meetpunt-FMN-021 ;
    sosa:observedProperty ex:property-verkeersintensiteit ;
    sosa:phenomenonTime [
        a time:Interval ;
        time:hasBeginning [ a time:Instant ; time:inXSDDateTime "2026-04-28T00:00:00"^^xsd:dateTime ] ;
        time:hasEnd       [ a time:Instant ; time:inXSDDateTime "2026-04-29T00:00:00"^^xsd:dateTime ]
    ] ;
    sosa:resultTime "2026-04-28T23:59:59"^^xsd:dateTime ;
    sosa:hasSimpleResult "2541"^^xsd:integer .

