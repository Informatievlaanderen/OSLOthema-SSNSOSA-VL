subgraph VOOR["❌ VOOR — Architectuurfouten"]
    F_EP["Erosiepoel_Mechelen\n❌ sosa:FeatureOfInterest alleen\n(ontbreekt sosa:Platform)"]
    F_WX["Waarnemer_X\n❌ prov:Agent\n(geen sosa:Sensor)"]
