    N_WX["Waarnemer_X\n✅ sosa:Sensor"]
    N_OC["ObsCollection_EM_20240901\n✅ sosa:ObservationCollection"]
    N_OB["Obs_SedimentVolume\nsosa:Observation"]
    N_RES["Result_SedimentVolume\n✅ 245.000 L\n✅ qudt:QuantityValue + unit:L"]
