@prefix sosa:   <http://www.w3.org/ns/sosa/> .
@prefix ssn:    <http://www.w3.org/ns/ssn/> .
@prefix time:   <http://www.w3.org/2006/time#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix qudt:   <http://qudt.org/schema/qudt/> .
@prefix unit:   <http://qudt.org/vocab/unit/> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:     <https://example.org/erosiepoel/> .

### INFRASTRUCTUUR

ex:Erosiepoel_Mechelen
    a sosa:Platform, sosa:FeatureOfInterest ;
    rdfs:label "Erosiepoel Mechelen"@nl ;
    rdfs:comment "Retentiepoel voor erosiesediment, beheerd door Stad Mechelen. Afmetingen: 10 m × 5 m × 5 m, maximaal volume: 250.000 liter."@nl ;
    sosa:isFeatureOfInterestOf ex:ObsCollection_EM_20240901 .

ex:Waarnemer_X
    a sosa:Sensor, sosa:System ;
    rdfs:label "Veldwaarnemer X"@nl ;
    sosa:implements ex:VeldmeetProcedure .

### PROCEDURE & OBSERVEERBARE EIGENSCHAPPEN

ex:VeldmeetProcedure
    a sosa:ObservingProcedure, sosa:Procedure ;
    rdfs:label "Visuele veldmeetprocedure erosiepoel"@nl ;
    rdfs:comment "Manuele schatting van het sedimentvolume door een veldwaarnemer ter plaatse, na een neerslagepisode."@nl .

ex:SedimentVolume
    a sosa:Property ;
    rdfs:label "Sedimentvolume"@nl ;
    rdfs:comment "Volume van neergeslagen erosiemateriaal (slib, modder) in de erosiepoel, uitgedrukt in liter."@nl .

### OBSERVATIES / ACTUATIES

ex:ObsCollection_EM_20240901
    a sosa:ObservationCollection, sosa:ExecutionCollection ;
    rdfs:label "Ochtendcontrole erosiepoel Mechelen — 1 september 2024"@nl ;
    sosa:hasMember ex:Obs_SedimentVolume_EM_20240901 ;
    sosa:hasFeatureOfInterest ex:Erosiepoel_Mechelen ;
    sosa:madeBySensor ex:Waarnemer_X ;
    sosa:usedProcedure ex:VeldmeetProcedure ;
    sosa:phenomenonTime ex:Instant_20240901_09u ;
    sosa:resultTime "2024-09-01T09:00:00"^^xsd:dateTime .

ex:Obs_SedimentVolume_EM_20240901
    a sosa:Observation, sosa:Execution ;
    sosa:observedProperty ex:SedimentVolume ;
    sosa:hasFeatureOfInterest ex:Erosiepoel_Mechelen ;
    sosa:phenomenonTime ex:Instant_20240901_09u ;
    sosa:hasResult ex:Result_SedimentVolume_EM_20240901 .

ex:Result_SedimentVolume_EM_20240901
    a qudt:QuantityValue ;
    qudt:numericValue "245000"^^xsd:decimal ;
    qudt:hasUnit unit:L .

ex:Instant_20240901_09u
    a time:Instant ;
    time:inXSDDateTime "2024-09-01T09:00:00"^^xsd:dateTime .
