# Oorspronkelijk ontvangen bestand — bevat architectuurfouten.
# Niet verwerkt door de pipeline (.ttl.bak-extensie).
# Zie erosiepoel_herzien.ttl voor de gecorrigeerde versie.
#
# Architectuurfouten:
#   F1: Erosiepoel_Mechelen enkel als sosa:FeatureOfInterest, niet als sosa:Platform
#   F2: Waarnemer_X als prov:Agent in plaats van sosa:Sensor
#   F3: Geen sosa:ObservationCollection — observatie staat los
#   F4: Geen sosa:usedProcedure op de observatie
#   F5: Resultaat als hasSimpleResult zonder eenheid

@prefix sosa:   <http://www.w3.org/ns/sosa/> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:     <https://example.org/erosiepoel/> .

# F1: enkel FeatureOfInterest, ontbreekt sosa:Platform
ex:Erosiepoel_Mechelen
    a sosa:FeatureOfInterest ;
    rdfs:label "Erosiepoel Mechelen"@nl .

# F2: prov:Agent in plaats van sosa:Sensor
ex:Waarnemer_X
    a prov:Agent ;
    rdfs:label "Veldwaarnemer X"@nl .

ex:SedimentVolume
    a sosa:ObservableProperty ;
    rdfs:label "Sedimentvolume"@nl .

# F3: losse observatie, geen ObservationCollection
# F4: ontbreekt sosa:usedProcedure
# F5: hasSimpleResult zonder eenheid
ex:Obs_Sediment_20240901
    a sosa:Observation ;
    sosa:hasFeatureOfInterest ex:Erosiepoel_Mechelen ;
    sosa:observedProperty ex:SedimentVolume ;
    sosa:resultTime "2024-09-01T09:00:00"^^xsd:dateTime ;
    sosa:hasSimpleResult "245000"^^xsd:decimal .
